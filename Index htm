    oldPrice: 25000, 
    img: "💎", 
    hot: false, 
    fileUrl: "https://www.thesecret.tv/wp-content/uploads/2015/04/The-Science-of-Getting-Rich.pdf" 
  },
  { 
    id: 'l1', 
