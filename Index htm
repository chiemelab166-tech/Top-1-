      <button onClick={() => setPage('shop')} className="bg-gold text-black px-12 py-5 rounded-2xl font-black text-xl hover:scale-105 transition shadow-[0_0_50px_rgba(212,175,55,0.3)]">ACCESS THE VAULT</button>
    </section>
    <div className="max-w-7xl mx-auto px-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 pb-32">
