  },
  { 
    id: 'l2', 
    title: "Meditations (Leadership Mastery)", 
    category: "Leadership", 
    price: 10000, 
    oldPrice: 40000, 
    img: "👑", 
    hot: true, 
    fileUrl: "http://classics.mit.edu/Antoninus/meditations.mb.txt" // Text version for stability
  },
  { 
    id: 'p1', 
    title: "The 80/20 Principle (Efficiency)", 
    category: "Productivity", 
    price: 7000, 
    oldPrice: 30000, 
    img: "⚙️", 
    hot: false, 
    fileUrl: "https://archive.org/download/8020-principle-the-richard-koch/80%2020%20Principle%2C%20The%20-%20Richard%20Koch.pdf" 
  }
];

const App = () => {
  const [page, setPage] = useState('home');
  const [user, setUser] = useState(null);
  const [books, setBooks] = useState([]);
  const [library, setLibrary] = useState([]);
  const [allOrders, setAllOrders] = useState([]);
  const [cart, setCart] = useState([]);
  const [notification, setNotification] = useState(null);
  const [adminMode, setAdminMode] = useState(false);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const initAuth = async () => {
      if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(auth, __initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, (u) => { setUser(u); setLoading(false); });
    return () => unsubscribe();
  }, []);

  useEffect(() => {
    if (!user) return;
    const booksRef = collection(db, 'artifacts', appId, 'public', 'data', 'books');
    onSnapshot(booksRef, (snap) => {
      if (snap.empty) {
        MASTER_CATALOG.forEach(b => setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'books', b.id), b));
      } else {
        setBooks(snap.docs.map(d => ({ id: d.id, ...d.data() })));
      }
    });
  }, [user]);

  useEffect(() => {
    if (!user) return;
    onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'purchases'), (snap) => {
      setLibrary(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    });
  }, [user]);

  useEffect(() => {
    if (!user || !adminMode) return;
    onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'orders'), (snap) => {
      setAllOrders(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    });
  }, [user, adminMode]);

  const notify = (msg) => { setNotification(msg); setTimeout(() => setNotification(null), 3000); };
  const addToCart = (i) => {
    if (cart.find(c => c.id === i.id)) return notify("Already in vault!");
    setCart([...cart, i]); notify("Added to selection");
  };
  const cartTotal = useMemo(() => cart.reduce((a, b) => a + b.price, 0), [cart]);

  const processPayment = async (method, meta = {}) => {
    const orderId = `1%-${Math.floor(1000 + Math.random() * 9000)}`;
    const payload = { 
      orderId, 
      userId: user.uid, 
      items: cart, 
      amount: cartTotal, 
      status: method === 'card' ? 'Completed' : 'Pending Verification', 
      method, 
      createdAt: new Date().toISOString(), 
      ...meta 
    };
    
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', orderId), payload);
    
    // Delivery Logic
    for (const item of cart) {
      await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'purchases', item.id), { 
        ...item, 
        unlocked: method === 'card' 
      });
    }
    
    setCart([]);
    setPage('success');
  };

  const approveOrder = async (order) => {
    await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'orders', order.id), { status: 'Completed' });
    for (const item of order.items) {
      await updateDoc(doc(db, 'artifacts', appId, 'users', order.userId, 'purchases', item.id), { unlocked: true });
    }
    notify("Transfer Verified!");
  };

  if (loading) return <div className="h-screen bg-black flex items-center justify-center font-bold text-gold">LOADING VAULT...</div>;

  return (
    <div className="min-h-screen bg-black text-white font-sans selection:bg-gold">
      <nav className="sticky top-0 z-50 bg-black/90 backdrop-blur-md border-b border-white/5 px-6 py-4 flex items-center justify-between">
        <h1 onClick={() => setPage('home')} className="text-2xl font-black cursor-pointer"><span className="bg-gold text-black px-2 rounded italic">TOP</span> 1%</h1>
        <div className="flex gap-6 items-center">
          <button onClick={() => setPage('shop')} className="text-xs font-bold uppercase text-zinc-500 hover:text-gold transition">Shop</button>
          <button onClick={() => setPage('account')} className="text-xs font-bold uppercase text-zinc-500 hover:text-gold transition">My Library</button>
          <button onClick={() => setPage('cart')} className="relative">
            <ShoppingBag size={20}/>
            {cart.length > 0 && <span className="absolute -top-2 -right-2 bg-gold text-black text-[10px] w-4 h-4 rounded-full flex items-center justify-center font-bold">{cart.length}</span>}
          </button>
          <button onClick={() => { setAdminMode(!adminMode); setPage(adminMode ? 'home' : 'admin'); }}><Shield size={20} className={adminMode ? 'text-gold' : 'text-zinc-700'}/></button>
        </div>
      </nav>

      <main className="min-h-[85vh]">
        {page === 'home' && <Home setPage={setPage} books={books} addToCart={addToCart} />}
        {page === 'shop' && <Shop books={books} addToCart={addToCart} />}
        {page === 'cart' && <Cart cart={cart} cartTotal={cartTotal} setPage={setPage} setCart={setCart} />}
        {page === 'checkout' && <Checkout cartTotal={cartTotal} processPayment={processPayment} />}
        {page === 'account' && <Library library={library} />}
        {page === 'admin' && <Admin allOrders={allOrders} approveOrder={approveOrder} />}
        {page === 'success' && <Success setPage={setPage} />}
      </main>

      <footer className="bg-zinc-950 py-12 border-t border-white/5 text-center text-[10px] font-black uppercase text-zinc-600 tracking-widest">
        Top 1% Global Marketplace • Built for Millionaires
      </footer>

      {notification && <div className="fixed bottom-10 right-10 z-[100] bg-gold text-black px-6 py-4 rounded-2xl font-black flex items-center gap-2 animate-in slide-in-from-bottom"><CheckCircle size={20}/> {notification}</div>}
      <a href="https://wa.me/2341965934069" target="_blank" className="fixed bottom-6 left-6 bg-green-500 p-4 rounded-full shadow-2xl z-50"><MessageCircle size={24}/></a>
    </div>
  );
};

